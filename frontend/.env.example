# CloudMentor frontend API target examples

# 1) Local laptop mode with SAM local backend
VITE_API_BASE_URL=http://localhost:3000

# 2) EC2-only classroom mode if EC2 proxies /api to a local backend on the machine
# VITE_API_BASE_URL=http://YOUR_EC2_PUBLIC_IP/api

# 3) Production mode used by GitHub Actions
# GitHub Actions injects the real API Gateway URL during npm run build.
# Do not hardcode production API values in Git.
# VITE_API_BASE_URL=https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com
